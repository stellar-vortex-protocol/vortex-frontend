# ─── Relay API ───────────────────────────────────────────────────────────────
# Base URL of the vortex-backend REST API
NEXT_PUBLIC_API_URL=http://localhost:4000
# WebSocket endpoint for the live intent feed
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws

# ─── Stellar ─────────────────────────────────────────────────────────────────
# Network to connect to: testnet | futurenet | mainnet
NEXT_PUBLIC_NETWORK=testnet

# Deployed contract IDs (leave blank until deployed)
NEXT_PUBLIC_SETTLEMENT_CONTRACT=
NEXT_PUBLIC_SOLVER_REGISTRY_CONTRACT=
